{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EdenFinTech Scan Report",
  "type": "object",
  "required": [
    "report_type",
    "title",
    "date",
    "version",
    "scan_parameters",
    "executive_summary",
    "ranked_candidates",
    "portfolio_impact",
    "rejected_at_screening",
    "rejected_at_analysis_detail_packets",
    "current_holding_overlays",
    "methodology_notes"
  ],
  "properties": {
    "report_type": {
      "type": "string",
      "const": "scan_report_v1"
    },
    "title": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "scan_parameters": {
      "type": "object",
      "required": ["universe", "focus", "stocks_scanned", "api"],
      "properties": {
        "universe": { "type": "string" },
        "focus": { "type": "string" },
        "stocks_scanned": { "type": "number" },
        "api": { "type": "string" }
      }
    },
    "executive_summary": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ranked_candidates": {
      "type": "array",
      "items": { "type": "object" }
    },
    "pending_human_review": {
      "type": "array",
      "items": { "type": "object" }
    },
    "portfolio_impact": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rejected_at_screening": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "failed_at", "reason"],
        "properties": {
          "ticker": { "type": "string" },
          "failed_at": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "rejected_at_analysis_detail_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "rejection_reason"],
        "properties": {
          "ticker": { "type": "string" },
          "rejection_reason": { "type": "string" }
        }
      }
    },
    "current_holding_overlays": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ticker",
          "status_in_scan",
          "new_capital_decision",
          "existing_position_action",
          "reason"
        ],
        "properties": {
          "ticker": { "type": "string" },
          "status_in_scan": {
            "type": "string",
            "enum": ["RANKED", "REJECTED_AT_SCREENING", "REJECTED_AT_ANALYSIS"]
          },
          "new_capital_decision": {
            "type": "string",
            "enum": ["ADD", "DO_NOT_ADD"]
          },
          "existing_position_action": {
            "type": "string",
            "enum": ["HOLD", "HOLD_AND_MONITOR", "TRIM", "REDUCE", "EXIT"]
          },
          "reason": { "type": "string" }
        }
      }
    },
    "methodology_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
